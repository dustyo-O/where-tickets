# Application environment: local | dev | staging | prod
APP_ENV=local

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://where_tickets:where_tickets@localhost:5432/where_tickets

# AWS Cognito (declared for later slices, unused in bootstrap)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=

# AWS Bedrock (declared for later slices, unused in bootstrap)
# BEDROCK_REGION=
# BEDROCK_MODEL_ID=
