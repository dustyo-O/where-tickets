{# Casa Atlas booking confirmation — fictional short-stay listing platform
   used only for the synthetic PDF corpus. Casual rounded layout, warm coral
   palette, hosted-by line. NOT associated with any real platform. The
   template prints every `cities[]` value and every YYYY-MM-DD date portion
   of the check-in/check-out datetimes verbatim so the validator's PDF/JSON
   token sanity check passes. #}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Casa Atlas — Reservation {{ data.scenario_id }}</title>
    <link rel="stylesheet" href="styles/casa-atlas.css">
</head>
<body class="font-{{ noise.font_pair }}">
    <header class="brand-header">
        <div class="brand-mark">
            <div class="hearth" aria-hidden="true"></div>
            <div>
                <div class="name">casa atlas</div>
                <div class="tagline">Fictional Homes, Real Test Data</div>
            </div>
        </div>
        <div class="doc-meta">
            <div class="doc-label">Reservation</div>
            <div>Ref: {{ data.scenario_id }}</div>
            <div>Issued: {{ stays[0].check_in_date }}</div>
            <div>Trip code: CA-{{ data.scenario_id[:3] }}</div>
        </div>
    </header>

    {% for partial in noise.partial_order %}
        {% if partial == "marketing_banner" and noise.marketing_banner_count > 0 %}
            {% include "partials/marketing_banner.html.j2" %}
        {% endif %}
    {% endfor %}

    <section class="route-summary">
        <h2>You're going to</h2>
        <p>
            {% for city in data.cities -%}
                <strong>{{ city }}</strong>{% if not loop.last %} &middot; {% endif %}
            {%- endfor %}
        </p>
    </section>

    <section class="stay-section">
        <h2>Your home for the trip</h2>
        <div class="stays">
            {% for stay in stays %}
            <div class="stay">
                <div class="listing">
                    <div class="listing-title">{{ stay.identifier }}</div>
                    <div class="listing-city">in {{ stay.city }}</div>
                    <div class="hosted-by">
                        Hosted by
                        {%- if data.travelers|length > 0 %}
                            {# Use the first traveler-pool slot as a fake host name;
                               real hosts are intentionally not separate data here
                               — keeping the schema lean is more important than
                               the host being its own field. #}
                            <strong>Mira (fictional Superhost)</strong>
                        {%- else %}
                            <strong>Atlas Host</strong>
                        {%- endif %}
                    </div>
                </div>
                <div class="dates">
                    <div class="endpoint check-in">
                        <span class="role">Check-in</span>
                        <span class="datetime">
                            <span class="label">From</span>{{ stay.check_in_date }}
                            <span class="label">at</span>{{ stay.check_in_time }}
                        </span>
                    </div>
                    <div class="connector">&#x1F3E1;</div>
                    <div class="endpoint check-out">
                        <span class="role">Check-out</span>
                        <span class="datetime">
                            <span class="label">By</span>{{ stay.check_out_date }}
                            <span class="label">at</span>{{ stay.check_out_time }}
                        </span>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <section class="travelers">
        <h2>Guest{{ 's' if data.travelers|length > 1 else '' }}</h2>
        <ul>
            {% for name in data.travelers %}
            <li>{{ name }}</li>
            {% endfor %}
        </ul>
    </section>

    <section class="price-section">
        <h2>Trip total</h2>
        {% for price in data.prices %}
        <div class="price-block">
            <span class="amount">{{ "%.2f"|format(price.amount) }}</span>
            <span class="currency">{{ price.currency }}</span>
        </div>
        {% endfor %}
    </section>

    {% if not noise.secondary_qr_placement %}
        {% include "partials/qr_block.html.j2" %}
    {% endif %}

    {% for partial in noise.partial_order %}
        {% if partial == "tc_block" and noise.tc_block %}
            {% include "partials/tc_block.html.j2" %}
        {% elif partial == "footer_ad" %}
            {% include "partials/footer_ad.html.j2" %}
        {% endif %}
    {% endfor %}

    {% if noise.secondary_qr_placement %}
        {% include "partials/qr_block.html.j2" %}
    {% endif %}

    <div class="footer">
        Casa Atlas is a fictional short-stay platform used only for synthetic
        PDF-extraction testing. Not affiliated with any real listing service.
        Scenario {{ data.scenario_id }}.
    </div>
</body>
</html>
