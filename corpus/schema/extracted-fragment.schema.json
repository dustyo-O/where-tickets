{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://where-tickets.local/schema/extracted-fragment.schema.json",
  "title": "Extracted Document Fragment",
  "description": "One fragment represents the structured payload extracted from one simulated travel document (ticket or hotel booking).",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/transitTicket" },
    { "$ref": "#/$defs/hotelBooking" }
  ],
  "$defs": {
    "isoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "cityCode": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "traveler": {
      "type": "string",
      "minLength": 1
    },
    "leg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "departureAt", "arrivalAt"],
      "properties": {
        "from": { "$ref": "#/$defs/cityCode" },
        "to": { "$ref": "#/$defs/cityCode" },
        "departureAt": { "$ref": "#/$defs/isoDateTime" },
        "arrivalAt": { "$ref": "#/$defs/isoDateTime" },
        "carrier": { "type": "string", "minLength": 1 },
        "vehicleNumber": { "type": "string", "minLength": 1 }
      }
    },
    "transitTicket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentType", "sourceDocumentId", "pnr", "travelers", "legs"],
      "properties": {
        "documentType": {
          "type": "string",
          "enum": ["air-ticket", "bus-ticket", "train-ticket"]
        },
        "sourceDocumentId": { "type": "string", "minLength": 1 },
        "pnr": { "type": "string", "minLength": 1 },
        "travelers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/traveler" }
        },
        "legs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/leg" }
        }
      }
    },
    "hotelBooking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentType", "sourceDocumentId", "confirmationCode", "travelers", "city", "checkInAt", "checkOutAt"],
      "properties": {
        "documentType": { "const": "hotel-booking" },
        "sourceDocumentId": { "type": "string", "minLength": 1 },
        "confirmationCode": { "type": "string", "minLength": 1 },
        "travelers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/traveler" }
        },
        "city": { "$ref": "#/$defs/cityCode" },
        "checkInAt": { "$ref": "#/$defs/isoDateTime" },
        "checkOutAt": { "$ref": "#/$defs/isoDateTime" },
        "hotelName": { "type": "string", "minLength": 1 }
      }
    }
  }
}
