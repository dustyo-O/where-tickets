backend/spikes/route_engine_algorithmic/runs/

# Mock-Document Corpus — Layer 2 (real PDFs, never committed)
# Real tickets/bookings carry personal data and must stay strictly local.
# The .gitkeep placeholder keeps the directory in the tree.
corpus/pdf/layer2/**
!corpus/pdf/layer2/.gitkeep
